{
  "version": 4,
  "terraform_version": "1.3.0",
  "serial": 1,
  "lineage": "test-lineage",
  "resources": [
    {
      "mode": "managed",
      "type": "aws_lambda_function",
      "name": "OrdersFunction",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "attributes": {
            "function_name": "OrdersFunction",
            "handler": "index.handler",
            "runtime": "nodejs14.x",
            "timeout": 30,
            "memory_size": 512
          }
        }
      ]
    },
    {
      "mode": "managed",
      "type": "aws_sqs_queue",
      "name": "OrdersQueue",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "attributes": {
            "name": "orders-queue",
            "visibility_timeout_seconds": 30
          }
        }
      ]
    },
    {
      "mode": "managed",
      "type": "aws_db_instance",
      "name": "MainDB",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "attributes": {
            "allocated_storage": 20,
            "engine": "mysql",
            "instance_class": "db.t3.micro",
            "multi_az": false,
            "storage_encrypted": false
          }
        }
      ]
    },
    {
      "mode": "managed",
      "type": "aws_s3_bucket",
      "name": "OrphanedBucket",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "attributes": {
            "bucket": "orphaned-bucket-12345",
            "versioning": {
              "enabled": false
            }
          }
        }
      ]
    }
  ]
}
